{
  "name": "scout-website",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "dev": "pnpm --filter @workspace/omniscout run dev",
    "build": "pnpm --filter @workspace/omniscout run build",
    "preview": "pnpm --filter @workspace/omniscout run preview",
    "typecheck": "pnpm --filter @workspace/omniscout run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
