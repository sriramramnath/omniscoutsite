{
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "outputDirectory": "artifacts/omniscout/dist",
  "headers": [
    {
      "source": "/og/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets|og|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
