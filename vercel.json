{
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "outputDirectory": "artifacts/omniscout/dist",
  "headers": [
    {
      "source": "/og/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets|og|downloads|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/downloads/probe-zero-mini-v0.2.17.tar.gz",
      "destination": "https://github.com/sriramramnath/omniscoutsite/releases/download/probe-zero-mini-v0.2.17/probe-zero-mini-v0.2.17.tar.gz",
      "permanent": false
    }
  ]
}
